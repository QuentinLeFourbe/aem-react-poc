  "devDependencies": {
    "@babel/eslint-parser": "7.28.6",
    "@eslint/js": "^10.0.1",
    "eslint": "10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.1"
  }
